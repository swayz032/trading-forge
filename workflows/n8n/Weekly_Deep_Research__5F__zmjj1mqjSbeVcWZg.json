    {
      "id": "code-cross-dedup-5f",
      "name": "Cross-Run Dedup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2000,
        500
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nlet ideas = [];\nlet fingerprints = [];\n\nfor (const item of items) {\n  const d = item.json;\n  if (d.ideas && Array.isArray(d.ideas)) ideas = d.ideas;\n  if (d.fingerprints && Array.isArray(d.fingerprints)) fingerprints = d.fingerprints;\n  if (d.url && d.title && !d.ideas) fingerprints.push(d);\n}\n\nif (ideas.length === 0) {\n  try { ideas = $('Any Ideas Found?').first().json.ideas || []; } catch(e) { ideas = []; }\n}\n\nconst existingUrls = new Set(fingerprints.map(f => f.url).filter(Boolean));\nconst existingTitles = new Set(fingerprints.map(f => (f.title || '').toLowerCase()).filter(t => t.length > 0));\n\nconst novel = ideas.filter(idea => {\n  if (existingUrls.has(idea.url)) return false;\n  if (existingTitles.has((idea.title || '').toLowerCase())) return false;\n  return true;\n});\n\nreturn [{ json: { ideas: novel, count: novel.length, dedupedOut: ideas.length - novel.length } }];"
      }
    },
