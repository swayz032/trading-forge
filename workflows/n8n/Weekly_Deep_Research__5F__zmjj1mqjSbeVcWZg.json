    {
      "id": "http-ollama-deep",
      "name": "Ollama Deep Analysis (qwen3-coder)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        2500,
        400
      ],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/generate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'qwen3-coder:30b', prompt: 'You are a senior quantitative trading researcher. For each research idea below, provide a JSON array with fields: title, novelty_score (1-10), feasibility_score (1-10), analysis (3 sentences about practical applicability to futures trading). Ideas:\\n' + JSON.stringify($json.ideas.map(function(i) { return { title: i.title, description: i.description, source: i.source }; })) + '\\n\\nRespond ONLY with a valid JSON array.', stream: false }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "continueOnFail": true
    },
    {
      "id": "code-deep-filter",
      "name": "Filter: Novelty>=5 AND Feasibility>=6",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2750,
        400
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst ollamaResponse = items[0]?.json;\n\nlet originalIdeas = [];\ntry { originalIdeas = $('Cross-Run Dedup').first().json.ideas || []; } catch(e) { originalIdeas = []; }\n\nlet scored = [];\ntry {\n  const responseText = ollamaResponse?.response || '';\n  const jsonMatch = responseText.match(/\\[[\\s\\S]*\\]/);\n  if (jsonMatch) scored = JSON.parse(jsonMatch[0]);\n} catch(e) {\n  scored = originalIdeas.map(i => ({ title: i.title, novelty_score: 6, feasibility_score: 7, analysis: i.description || '' }));\n}\n\nconst enriched = [];\nfor (let i = 0; i < originalIdeas.length; i++) {\n  const orig = originalIdeas[i];\n  const score = scored.find(s => s.title && orig.title && s.title.toLowerCase().includes(orig.title.substring(0, 20).toLowerCase())) || scored[i] || {};\n  const novelty = score.novelty_score || 5;\n  const feasibility = score.feasibility_score || 5;\n  if (novelty >= 5 && feasibility >= 6) {\n    enriched.push({ ...orig, novelty_score: novelty, feasibility_score: feasibility, analysis: score.analysis || '', source_quality: orig.source === 'tavily' ? 'deep_search' : orig.source === 'arxiv' ? 'academic' : 'web', confidence_score: Math.min((novelty + feasibility) / 20, 1.0) });\n  }\n}\n\nreturn [{ json: { ideas: enriched, count: enriched.length } }];"
      }
    },
