      "name": "Tavily Budget Check (60/mo)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        250,
        400
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst now = new Date();\nconst currentMonth = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;\n\nif (staticData.tavilyMonth !== currentMonth) {\n  staticData.tavilyMonth = currentMonth;\n  staticData.tavilyCallCount = 0;\n}\n\nconst tavilyCallCount = staticData.tavilyCallCount || 0;\nconst tavilyLimit = 60;\nconst skipTavily = tavilyCallCount >= tavilyLimit;\n\nreturn [{\n  json: {\n    skipTavily,\n    tavilyCallCount,\n    tavilyLimit,\n    tavilyRemaining: tavilyLimit - tavilyCallCount,\n    currentMonth,\n    timestamp: now.toISOString()\n  }\n}];"
      }
