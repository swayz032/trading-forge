    {
      "id": "code-parse-arxiv",
      "name": "Parse arXiv Atom XML",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        850
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const item = $input.first();\nconst xmlText = item.json.data || item.json || '';\nconst xmlStr = typeof xmlText === 'string' ? xmlText : JSON.stringify(xmlText);\n\nconst papers = [];\nconst thirtyDaysAgo = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);\n\n// Simple XML parsing for Atom feed entries\nconst entryRegex = /<entry>(.*?)<\\/entry>/gs;\nlet match;\nwhile ((match = entryRegex.exec(xmlStr)) !== null) {\n  const entry = match[1];\n  const title = (entry.match(/<title[^>]*>(.*?)<\\/title>/s) || [])[1]?.trim().replace(/\\s+/g, ' ') || '';\n  const summary = (entry.match(/<summary[^>]*>(.*?)<\\/summary>/s) || [])[1]?.trim().replace(/\\s+/g, ' ') || '';\n  const published = (entry.match(/<published>(.*?)<\\/published>/) || [])[1] || '';\n  const link = (entry.match(/<id>(.*?)<\\/id>/) || [])[1] || '';\n\n  if (published && new Date(published) >= thirtyDaysAgo) {\n    papers.push({\n      source: 'arxiv',\n      title,\n      description: summary.substring(0, 400),\n      url: link,\n      published\n    });\n  }\n}\n\nreturn [{ json: { papers, count: papers.length } }];"
      }
    },
    {
      "id": "merge-tavily",
      "name": "Merge Tavily Results",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [
        1000,
        400
      ],
      "parameters": {
        "mode": "append"
      }
