    {
      "parameters": {
        "jsCode": "const profiles = $input.first().json;\nconst prepData = $('Kill Switch + Prep').first().json;\n\nif (!Array.isArray(profiles) || profiles.length === 0) {\n  return [{ json: { skip: 'true', reason: 'no_eligible_profiles', correlationId: prepData.correlationId } }];\n}\n\n// Emit one item per profile for the orchestrator loop\nreturn profiles.map(profile => ({\n  json: {\n    skip: 'false',\n    suiteId: profile.suite_id,\n    requestId: prepData.requestId + '-' + profile.suite_id.slice(0, 8),\n    correlationId: prepData.correlationId,\n    idempotencyKey: prepData.idempotencyKey + '-' + profile.suite_id.slice(0, 8),\n    context: {\n      industry: profile.industry,\n      industrySpecialty: profile.industry_specialty,\n      incomeRange: profile.income_range,\n      referralSource: profile.referral_source,\n      businessGoals: profile.business_goals,\n      painPoint: profile.pain_point,\n      customerType: profile.customer_type,\n      salesChannel: profile.sales_channel,\n      teamSize: profile.team_size\n    }\n  }\n}));"
      },
