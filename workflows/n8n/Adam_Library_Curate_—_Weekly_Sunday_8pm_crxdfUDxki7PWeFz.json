      "parameters": {
        "jsCode": "const prepData = $('Kill Switch + Prep').first().json;\nconst profiles = $input.first().json;\nconst profile = Array.isArray(profiles) && profiles.length > 0 ? profiles[0] : null;\n\nconst context = profile ? {\n  industry: profile.industry,\n  industrySpecialty: profile.industry_specialty,\n  incomeRange: profile.income_range,\n  referralSource: profile.referral_source,\n  businessGoals: profile.business_goals,\n  painPoint: profile.pain_point,\n  customerType: profile.customer_type,\n  salesChannel: profile.sales_channel,\n  teamSize: profile.team_size\n} : null;\n\n// Derive content categories from industry specialty for targeted curation\nconst serviceCategories = profile && profile.industry_specialty ? [profile.industry_specialty.toLowerCase().replace(/[^a-z0-9]+/g, '_')] : [];\n\nreturn [{ json: { ...prepData, context, serviceCategories } }];"
      },
