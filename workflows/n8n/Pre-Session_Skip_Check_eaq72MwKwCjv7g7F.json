  "nodes": [
    {
      "id": "trigger-schedule",
      "name": "Weekday 9AM ET Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        0,
        0
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * 1-5"
            }
          ]
        }
      }
    },
    {
      "id": "http-get-skip",
      "name": "GET Skip Decisions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        220,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:4000/api/skip/today",
        "options": {
          "timeout": 10000
        }
      },
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 5000,
      "onError": "continueRegularOutput",
      "continueOnFail": true
    },
    {
      "id": "code-parse-decisions",
      "name": "Parse Skip Decisions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        0
      ],
      "parameters": {
        "jsCode": "const response = $input.first().json;\n\nconst decisions = Array.isArray(response) ? response : (response.decisions || response.data || []);\n\nconst trade = [];\nconst reduce = [];\nconst skip = [];\n\nfor (const d of decisions) {\n  const name = d.strategyName || d.strategy || d.name || 'Unknown';\n  const reason = d.reason || d.rationale || '';\n  const decision = (d.decision || d.action || 'TRADE').toUpperCase();\n\n  if (decision === 'SKIP') {\n    skip.push({ name, reason });\n  } else if (decision === 'REDUCE') {\n    reduce.push({ name, reason });\n  } else {\n    trade.push({ name, reason });\n  }\n}\n\nreturn [{\n  json: {\n    hasSkips: skip.length > 0,\n    hasReduces: reduce.length > 0,\n    trade,\n    reduce,\n    skip,\n    totalStrategies: decisions.length,\n    timestamp: new Date().toISOString()\n  }\n}];"
      }
    },
    {
      "id": "if-any-skips",
      "name": "Any SKIP Decisions?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        660,
        -80
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-skip",
              "leftValue": "={{ $json.hasSkips }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "code-format-skip-alert",
      "name": "Format SKIP Alert",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        -180
      ],
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst skipLines = data.skip.map(s => `- ${s.name}: ${s.reason}`).join('\\n');\n\nreturn [{\n  json: {\n    title: 'Strategies Skipped Today',\n    message: `${data.skip.length} strategies will be SKIPPED today\\n\\n${skipLines}`,\n    severity: 'warning',\n    data: {\n      skipCount: String(data.skip.length),\n      strategies: data.skip.map(s => s.name).join(', '),\n      timestamp: data.timestamp\n    }\n  }\n}];"
      }
    },
    {
      "id": "http-post-skip-alert",
      "name": "POST SKIP Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1100,
        -180
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:4100/alert/skip",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify(Object.assign({}, $json, { type: 'SKIP' })) }}",
        "options": {
          "timeout": 10000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "continueOnFail": true
    },
    {
      "id": "if-any-reduces",
      "name": "Any REDUCE Decisions?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        660,
        120
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-reduce",
              "leftValue": "={{ $json.hasReduces }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "code-format-reduce-alert",
      "name": "Format REDUCE Advisory",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        60
      ],
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst reduceLines = data.reduce.map(r => `- ${r.name}: ${r.reason}`).join('\\n');\n\nreturn [{\n  json: {\n    title: 'Strategies Reduced Today',\n    message: `${data.reduce.length} strategies with reduced sizing\\n\\n${reduceLines}`,\n    severity: 'info',\n    data: {\n      reduceCount: String(data.reduce.length),\n      strategies: data.reduce.map(r => r.name).join(', '),\n      timestamp: data.timestamp\n    }\n  }\n}];"
      }
    },
    {
      "id": "http-post-reduce-alert",
      "name": "POST REDUCE Advisory",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1100,
        60
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:4100/alert/skip",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify(Object.assign({}, $json, { type: 'REDUCE' })) }}",
        "options": {
          "timeout": 10000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "continueOnFail": true
    },
    {
      "id": "code-session-briefing",
      "name": "Build Session Briefing",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        0
      ],
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst today = new Date();\nconst dateStr = today.toISOString().split('T')[0];\n\nconst briefing = {\n  date: dateStr,\n  trade: data.trade.map(t => t.name),\n  reduce: data.reduce.map(r => `${r.name} (${r.reason})`),\n  skip: data.skip.map(s => `${s.name} (${s.reason})`),\n  summary: {\n    totalStrategies: data.totalStrategies,\n    tradingCount: data.trade.length,\n    reduceCount: data.reduce.length,\n    skipCount: data.skip.length\n  },\n  timestamp: data.timestamp\n};\n\nreturn [{\n  json: briefing\n}];"
      }
    },
    {
      "id": "http-post-briefing",
      "name": "POST Session Briefing",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1540,
        0
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:4100/alert/skip",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ type: 'BRIEFING', title: 'Pre-Session Briefing', message: 'Trading: ' + ($json.summary ? $json.summary.tradingCount : 0) + ' | Reduce: ' + ($json.summary ? $json.summary.reduceCount : 0) + ' | Skip: ' + ($json.summary ? $json.summary.skipCount : 0) + ' (Total: ' + ($json.summary ? $json.summary.totalStrategies : 0) + ')', severity: 'info', data: { date: $json.date || '', tradingCount: String($json.summary ? $json.summary.tradingCount : 0), reduceCount: String($json.summary ? $json.summary.reduceCount : 0), skipCount: String($json.summary ? $json.summary.skipCount : 0), totalStrategies: String($json.summary ? $json.summary.totalStrategies : 0) } }) }}",
        "options": {
          "timeout": 10000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "continueOnFail": true
    },
    {
