        "jsonBody": "={{ JSON.stringify({ receipt_id: 'n8n-cert-check-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8), suite_id: ($env.DEFAULT_SUITE_ID || 'ffffffff-0000-0000-0000-system000000'), tenant_id: 'system', office_id: ($env.DEFAULT_OFFICE_ID || $env.DEFAULT_SUITE_ID || 'ffffffff-0000-0000-0000-system000000'), receipt_type: 'n8n_ops', status: $json.anyDown ? 'FAILED' : 'SUCCEEDED', correlation_id: $('Kill Switch + Prep').item.json.correlationId, actor_type: 'SYSTEM', actor_id: 'n8n-cert-renewal', action: { action_type: 'ops.cert_expiry_check', risk_tier: 'green', domains: $json.domains, any_down: $json.anyDown }, created_at: new Date().toISOString() }) }}",
