          "jsCode": "// Generate per-job idempotency key and prepare the request body.\nconst crypto = require('crypto');\nconst job = $input.item.json;\nconst today = new Date().toISOString().slice(0, 10);\n\nconst payloadHash = crypto.createHash('sha256').update(JSON.stringify({\n  secret_id: job.secret_id,\n  adapter: job.adapter,\n  date: today\n})).digest('hex');\n\nconst jobIdempotencyKey = crypto.createHash('sha256').update(\n  job.parent_request_id + 'ops.trigger_rotation.' + job.secret_id + payloadHash\n).digest('hex');\n\nreturn [{ json: {\n  ...job,\n  idempotency_key: jobIdempotencyKey,\n  request_body: {\n    secret_id: job.secret_id,\n    adapter: job.adapter,\n    correlation_id: job.correlation_id,\n    triggered_by: job.triggered_by,\n    idempotency_key: jobIdempotencyKey,\n    rotation_interval_days: job.rotation_interval_days\n  }\n} }];"
