      {
        "parameters": {
          "jsCode": "// Build rotation job list with jitter to avoid thundering herd.\nconst schedule = [\n  { secret_id: 'stripe', adapter: 'stripe', rotation_interval_days: 30 },\n  { secret_id: 'twilio', adapter: 'twilio', rotation_interval_days: 90 },\n  { secret_id: 'openai', adapter: 'openai', rotation_interval_days: 90 },\n  { secret_id: 'internal', adapter: 'internal', rotation_interval_days: 90 },\n  { secret_id: 'supabase', adapter: 'supabase', rotation_interval_days: 90 },\n  { secret_id: 'providers', adapter: 'deepgram', rotation_interval_days: 90 }\n];\n\nconst parentCorrelationId = $('Kill Switch + Prep').item.json.correlationId;\nconst parentRequestId = $('Kill Switch + Prep').item.json.requestId;\n\nconst jobs = schedule.map((s, idx) => {\n  const jitterMs = Math.floor(Math.random() * 60 * 60 * 1000);\n  const jitterSeconds = Math.floor(jitterMs / 1000);\n  return {\n    secret_id: s.secret_id,\n    adapter: s.adapter,\n    rotation_interval_days: s.rotation_interval_days,\n    correlation_id: parentCorrelationId + '-' + s.secret_id,\n    parent_correlation_id: parentCorrelationId,\n    parent_request_id: parentRequestId,\n    triggered_by: 'n8n-schedule',\n    jitter_seconds: jitterSeconds,\n    job_index: idx,\n    total_jobs: schedule.length\n  };\n});\n\nreturn jobs.map(j => ({ json: j }));"
        },
        "id": "build-rotation-jobs",
        "name": "Build Rotation Jobs",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
