  "name": "Daily Portfolio Monitor",
  "description": null,
  "active": true,
  "isArchived": false,
  "nodes": [
    {
      "id": "schedule-trigger",
      "name": "5PM EST Weekday Trigger",
      "parameters": {
        "rule": {
          "interval": [
            {
              "expression": "0 17 * * 1-5",
              "field": "cronExpression"
            }
          ]
        }
      },
      "position": [
        0,
        300
      ],
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3
    },
    {
      "id": "fetch-deployed",
      "maxTries": 3,
      "name": "Fetch DEPLOYED Strategies",
      "parameters": {
        "options": {},
        "url": "http://localhost:3000/api/strategies?lifecycle_state=DEPLOYED"
      },
      "position": [
        224,
        300
      ],
      "retryOnFail": true,
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "waitBetweenTries": 5000
    },
    {
      "id": "check-any-deployed",
      "name": "Any DEPLOYED Strategies?",
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-has-strategies",
              "leftValue": "={{ $json.length > 0 }}",
              "operator": {
                "operation": "equals",
                "type": "boolean"
              },
              "rightValue": true
            }
          ],
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          }
        },
        "options": {}
      },
      "position": [
        448,
        300
      ],
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3
    },
    {
      "id": "log-no-strategies",
      "name": "Log No DEPLOYED Strategies",
      "parameters": {
        "jsonBody": "={ \"type\": \"portfolio_monitor\", \"message\": \"No DEPLOYED strategies found - nothing to monitor\", \"timestamp\": \"{{ $now.toISO() }}\" }",
        "method": "POST",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "url": "http://localhost:3000/api/journal"
      },
      "position": [
        672,
        500
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4
    },
    {
      "id": "split-strategies",
      "name": "Loop Over Strategies",
      "parameters": {
        "options": {}
      },
      "position": [
        672,
        300
      ],
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3
    },
    {
      "id": "compute-sharpe",
      "name": "Compute Rolling Sharpe",
      "parameters": {
        "jsCode": "const strategy = $input.first().json;\n\nconst rollingSharpe = Number(strategy.rolling_sharpe_30d || strategy.sharpeRatio || 0);\nconst strategyId = strategy.id;\nconst strategyName = strategy.name || strategy.strategy_name || 'Unknown';\n\nreturn [{\n  json: {\n    strategyId,\n    strategyName,\n    rolling_sharpe_30d: rollingSharpe,\n    drifting: rollingSharpe < 1.0,\n    lifecycle_state: strategy.lifecycle_state || 'DEPLOYED'\n  }\n}];"
      },
      "position": [
        896,
        100
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "check-drift",
      "name": "Detect Drift",
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-drift",
              "leftValue": "={{ $json.drifting }}",
              "operator": {
                "operation": "equals",
                "type": "boolean"
              },
              "rightValue": true
            }
          ],
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          }
        },
        "options": {}
      },
      "position": [
        1120,
        100
      ],
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3
    },
    {
      "id": "transition-declining",
      "maxTries": 2,
      "name": "Log Drift Alert and Transition",
      "parameters": {
        "jsonBody": "={ \"fromState\": \"DEPLOYED\", \"toState\": \"DECLINING\" }",
        "method": "PATCH",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "url": "=http://localhost:3000/api/strategies/{{ $json.strategyId }}/lifecycle"
      },
      "position": [
        1344,
        0
      ],
      "retryOnFail": true,
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "waitBetweenTries": 3000
    },
    {
      "id": "log-healthy",
      "name": "Log Healthy",
      "parameters": {},
      "position": [
        1344,
        200
      ],
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1
    },
    {
      "id": "fetch-pipeline",
      "maxTries": 2,
      "name": "Fetch Pipeline Health",
      "parameters": {
        "options": {},
        "url": "http://localhost:3000/api/strategies/pipeline"
      },
      "position": [
        896,
        500
      ],
      "retryOnFail": true,
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "waitBetweenTries": 3000
    },
    {
      "id": "build-summary",
      "name": "Build Summary",
      "parameters": {
        "jsCode": "const pipeline = $input.first().json;\n\nconst lines = [\n  '=== Daily Portfolio Monitor Summary ===',\n  `Date: ${new Date().toISOString().split('T')[0]}`,\n  '',\n  '--- Pipeline Health ---'\n];\n\nconst states = ['CANDIDATE', 'TESTING', 'PAPER', 'DEPLOYED', 'DECLINING', 'RETIRED'];\nfor (const state of states) {\n  const count = pipeline[state] || pipeline[state.toLowerCase()] || 0;\n  lines.push(`  ${state}: ${count}`);\n}\n\nlines.push('');\nlines.push('--- End of Report ---');\n\nreturn [{\n  json: {\n    type: 'portfolio_monitor_daily',\n    summary: lines.join('\\n'),\n    pipeline: pipeline,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "position": [
        1120,
        500
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "log-journal",
      "maxTries": 2,
      "name": "Log Summary to Journal",
      "parameters": {
        "jsonBody": "={{ JSON.stringify($json) }}",
        "method": "POST",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "url": "http://localhost:3000/api/journal"
      },
      "position": [
        1344,
        500
      ],
      "retryOnFail": true,
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "waitBetweenTries": 3000
    },
    {
      "id": "error-trigger-pm",
      "name": "On Workflow Error",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        0,
        700
      ],
      "parameters": {}
    },
    {
      "id": "http-error-alert-pm",
      "name": "Discord Portfolio Monitor Error",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        250,
        700
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:4100/alert/alerts",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ title: 'Portfolio Monitor Error', message: $input.first().json.execution ? ($input.first().json.execution.error ? $input.first().json.execution.error.message : 'Unknown error') : ($input.first().json.error ? $input.first().json.error.message : JSON.stringify($input.first().json).substring(0, 500)), severity: 'critical', data: { workflow: 'Daily Portfolio Monitor', timestamp: new Date().toISOString() } }) }}",
        "options": {
          "timeout": 10000
        }
      },
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 2000,
      "onError": "continueRegularOutput"
    }
  ],
