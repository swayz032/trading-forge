              "expression": "0 5 * * *"
            }
          ]
        }
      }
    },
    {
      "id": "fetch-stats",
      "name": "Fetch Pipeline Stats",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        -200
      ],
      "continueOnFail": true,
      "parameters": {
        "url": "http://host.docker.internal:4000/api/journal/stats/summary",
        "method": "GET",
        "options": {
          "timeout": 30000
        }
      },
      "retryOnFail": true,
      "maxTries": 2,
      "onError": "continueRegularOutput"
    },
    {
      "id": "format-summary",
      "name": "Format Daily Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        550,
        0
      ],
      "parameters": {
        "jsCode": "const health = $('Check System Health').first().json;\nconst stats = $('Fetch Pipeline Stats').first().json;\nconst strategies = $('Check Strategy Pipeline').first().json;\n\nconst s = stats.data || stats;\nconst strats = strategies.data || strategies;\nconst stratList = Array.isArray(strats) ? strats : [];\n\nconst healthStatus = health.status || health.error || 'unknown';\nconst activeCount = stratList.filter(s => s.lifecycleState === 'ACTIVE' || s.lifecycleState === 'PAPER').length;\nconst testingCount = stratList.filter(s => s.lifecycleState === 'TESTING').length;\nconst decayCount = stratList.filter(s => s.lifecycleState === 'DECLINING' || s.decaying).length;\n\nconst lines = [\n  'System Health: ' + healthStatus,\n  'Total Strategies: ' + stratList.length,\n  'Active/Paper: ' + activeCount,\n  'Testing: ' + testingCount,\n  'Declining: ' + decayCount,\n  'Ideas sourced: ' + (s.totalIdeas ?? s.ideas ?? 'N/A'),\n  'Backtests run: ' + (s.totalBacktests ?? s.backtests ?? 'N/A'),\n  'Pass rate: ' + (s.passRate ?? 'N/A')\n];\n\nconst severity = healthStatus !== 'ok' ? 'warning' : 'info';\nreturn [{ json: { event: 'orchestration:daily-summary', data: { title: 'Daily Pipeline Summary (5 AM ET)', severity, body: lines.join('\\n'), healthStatus, strategyCount: stratList.length, activeCount, testingCount, decayCount } } }];"
      }
    },
    {
      "id": "send-alert",
      "name": "Send Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        770,
        0
      ],
      "continueOnFail": true,
      "parameters": {
        "url": "http://host.docker.internal:4000/api/sse/broadcast",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "timeout": 15000
        }
      },
      "retryOnFail": true,
      "maxTries": 2,
      "onError": "continueRegularOutput"
    },
    {
