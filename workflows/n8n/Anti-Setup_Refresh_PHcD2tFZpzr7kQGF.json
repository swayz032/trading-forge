        "jsonBody": "={{ JSON.stringify({ title: 'Anti-Setup Refresh: No Strategies', message: $json.message || 'No active strategies found', severity: 'info', data: { reportDate: $json.report_date || new Date().toISOString().split('T')[0] } }) }}",
        "options": {
          "timeout": 30000
        }
      },
