    {
      "id": "fetch-active-strategies",
      "name": "Fetch Active Strategies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        260,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "http://host.docker.internal:4000/api/strategies?status=active",
        "options": {
          "timeout": 30000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "continueOnFail": true
    },
    {
      "id": "extract-ids",
      "name": "Extract Strategy IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        300
      ],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst response = items[0].json;\n\n// Handle various API response shapes\nlet strategies = [];\nif (Array.isArray(response)) {\n  strategies = response;\n} else if (response.data && Array.isArray(response.data)) {\n  strategies = response.data;\n} else if (response.strategies && Array.isArray(response.strategies)) {\n  strategies = response.strategies;\n}\n\nif (strategies.length === 0) {\n  return [{\n    json: {\n      _noStrategies: true,\n      report_date: new Date().toISOString().split('T')[0],\n      strategies_analyzed: 0,\n      total_anti_setups_found: 0,\n      by_strategy: [],\n      message: 'No active strategies found'\n    }\n  }];\n}\n\n// Return each strategy as a separate item for SplitInBatches\nreturn strategies.map(s => ({\n  json: {\n    strategy_id: s.id || s.strategy_id,\n    strategy_name: s.name || s.strategy_name || s.id || 'Unknown',\n    total_strategies: strategies.length\n  }\n}));"
      }
    },
    {
      "id": "check-has-strategies",
      "name": "Has Strategies?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        780,
        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "combinator": "and",
          "conditions": [
            {
              "id": "has-strats",
              "leftValue": "={{ $json._noStrategies }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "notExists"
              }
            }
          ]
        }
      }
    },
    {
      "id": "split-batches",
      "name": "Loop Over Strategies",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        1040,
        200
      ],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "mine-anti-setups",
      "name": "Mine Anti-Setups",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1300,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:4000/api/anti-setups/mine",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ strategy_id: $json.strategy_id, lookback_days: 90 }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "waitBetweenTries": 10000,
      "continueOnFail": true
    },
    {
      "id": "parse-mining-result",
      "name": "Parse Mining Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        300
      ],
      "parameters": {
        "jsCode": "const items = $input.all();\nconst response = items[0].json;\n\n// Get the strategy info from the loop item (use modern syntax)\nconst strategyName = $('Loop Over Strategies').first().json.strategy_name;\nconst strategyId = $('Loop Over Strategies').first().json.strategy_id;\n\n// Parse anti-setup count from response\nlet antiSetupCount = 0;\nlet estimatedPnlImpact = '$0';\n\nif (response.anti_setups && Array.isArray(response.anti_setups)) {\n  antiSetupCount = response.anti_setups.length;\n} else if (typeof response.count === 'number') {\n  antiSetupCount = response.count;\n} else if (response.results && Array.isArray(response.results)) {\n  antiSetupCount = response.results.length;\n}\n\nif (response.estimated_pnl_impact) {\n  estimatedPnlImpact = response.estimated_pnl_impact;\n} else if (response.pnl_impact) {\n  estimatedPnlImpact = response.pnl_impact;\n}\n\nreturn [{\n  json: {\n    strategy: strategyName,\n    strategy_id: strategyId,\n    anti_setups: antiSetupCount,\n    estimated_pnl_impact: estimatedPnlImpact,\n    raw_response: response\n  }\n}];"
      }
    },
    {
      "id": "aggregate-results",
      "name": "Aggregate Final Report",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1300,
        100
      ],
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Collect all mining results from the loop\nconst byStrategy = items.map(item => ({\n  strategy: item.json.strategy || 'Unknown',\n  strategy_id: item.json.strategy_id || 'unknown',\n  anti_setups: item.json.anti_setups || 0,\n  estimated_pnl_impact: item.json.estimated_pnl_impact || '$0'\n}));\n\nconst totalAntiSetups = byStrategy.reduce((sum, s) => sum + s.anti_setups, 0);\n\nconst report = {\n  report_date: new Date().toISOString().split('T')[0],\n  strategies_analyzed: byStrategy.length,\n  total_anti_setups_found: totalAntiSetups,\n  by_strategy: byStrategy,\n  generated_at: new Date().toISOString()\n};\n\nreturn [{ json: report }];"
      }
    },
    {
      "id": "post-report",
      "name": "POST Anti-Setup Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1560,
        100
      ],
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:4100/alert/alerts",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ title: 'Anti-Setup Refresh Report', message: 'Analyzed ' + ($json.strategies_analyzed || 0) + ' strategies, found ' + ($json.total_anti_setups_found || 0) + ' anti-setups', severity: ($json.total_anti_setups_found > 0) ? 'warning' : 'info', data: { reportDate: $json.report_date || '', strategiesAnalyzed: String($json.strategies_analyzed || 0), totalAntiSetups: String($json.total_anti_setups_found || 0), generatedAt: $json.generated_at || new Date().toISOString() } }) }}",
        "options": {
          "timeout": 30000
        }
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 2,
      "continueOnFail": true
    },
    {
      "id": "post-empty-report",
      "name": "POST Empty Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1040,
