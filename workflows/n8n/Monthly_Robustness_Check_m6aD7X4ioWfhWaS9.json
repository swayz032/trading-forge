  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 6 1 * *"
            }
          ]
        }
      },
      "id": "schedule-trigger",
      "name": "Monthly 1st 6AM EST",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        0,
        88
      ]
    },
    {
      "parameters": {
        "url": "http://localhost:3000/api/strategies?lifecycle_state=DEPLOYED",
        "options": {}
      },
      "id": "fetch-deployed",
      "name": "Fetch Deployed Strategies",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        224,
        88
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "split-batches",
      "name": "Loop Over Strategies",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        448,
        88
      ]
    },
    {
      "parameters": {
        "jsCode": "const current = $input.first().json;\nconst original = $('Loop Over Strategies').first().json;\n\nconst sharpeDrop = original.sharpeRatio > 0 \n  ? (Number(original.sharpeRatio) - Number(current.sharpeRatio)) / Number(original.sharpeRatio) \n  : 0;\nconst winRateDrop = Number(original.winRate) - Number(current.winRate);\n\nconst degraded = sharpeDrop > 0.20 || winRateDrop > 0.10;\n\nreturn [{\n  json: {\n    strategyId: current.strategyId,\n    strategyName: original.name,\n    degraded,\n    sharpeDrop: (sharpeDrop * 100).toFixed(1) + '%',\n    winRateDrop: (winRateDrop * 100).toFixed(1) + '%',\n    currentSharpe: current.sharpeRatio,\n    originalSharpe: original.sharpeRatio,\n    currentWinRate: current.winRate,\n    originalWinRate: original.winRate,\n  }\n}];"
      },
      "id": "compare-metrics",
      "name": "Compare Metrics",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1344,
        -128
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-degraded",
              "leftValue": "={{ $json.degraded }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-degraded",
      "name": "Degraded?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        1568,
        -128
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:4000/api/journal",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"type\": \"robustness_alert\",\n  \"strategyId\": \"{{ $json.strategyId }}\",\n  \"strategyName\": \"{{ $json.strategyName }}\",\n  \"message\": \"Strategy degradation detected - flagged for review\",\n  \"sharpeDrop\": \"{{ $json.sharpeDrop }}\",\n  \"winRateDrop\": \"{{ $json.winRateDrop }}\",\n  \"currentSharpe\": {{ $json.currentSharpe }},\n  \"originalSharpe\": {{ $json.originalSharpe }},\n  \"currentWinRate\": {{ $json.currentWinRate }},\n  \"originalWinRate\": {{ $json.originalWinRate }},\n  \"flagForReview\": true,\n  \"timestamp\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
      },
      "id": "log-degraded",
      "name": "Log Degradation to Journal",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1792,
        -56
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:4000/api/journal",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"type\": \"robustness_check\",\n  \"strategyId\": \"{{ $json.strategyId }}\",\n  \"strategyName\": \"{{ $json.strategyName }}\",\n  \"message\": \"Strategy still healthy\",\n  \"currentSharpe\": {{ $json.currentSharpe }},\n  \"originalSharpe\": {{ $json.originalSharpe }},\n  \"currentWinRate\": {{ $json.currentWinRate }},\n  \"originalWinRate\": {{ $json.originalWinRate }},\n  \"flagForReview\": false,\n  \"timestamp\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
      },
      "id": "log-healthy",
      "name": "Log Healthy to Journal",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1792,
        136
      ],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "submit-robustness",
      "name": "Submit Robustness Test",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        672,
        -128
      ],
      "parameters": {
        "method": "POST",
        "url": "http://localhost:3000/api/agents/robustness",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={ \"strategyId\": \"{{ $json.id }}\", \"config\": {{ JSON.stringify($json.config) }} }",
        "options": {}
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "wait-robustness",
      "name": "Wait 2 Min for Robustness",
