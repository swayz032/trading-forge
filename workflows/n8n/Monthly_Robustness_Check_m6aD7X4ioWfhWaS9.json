      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1120,
        -128
      ],
      "parameters": {
        "url": "=http://localhost:3000/api/agents/jobs/{{ $('Submit Robustness Test').item.json.jobId }}",
        "options": {}
      },
      "onError": "continueRegularOutput",
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000
    },
    {
      "id": "check-job-complete",
      "name": "Job Complete?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        1344,
        -128
      ],
      "parameters": {
        "conditions": {
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-job-done",
              "leftValue": "={{ $json.status }}",
              "rightValue": "completed",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      }
    },
    {
      "id": "transition-declining",
      "name": "Transition to DECLINING",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        2016,
        -56
      ],
      "parameters": {
        "method": "PATCH",
        "url": "=http://localhost:3000/api/strategies/{{ $json.strategyId }}/lifecycle",
        "sendBody": true,
        "specifyBody": "json",
