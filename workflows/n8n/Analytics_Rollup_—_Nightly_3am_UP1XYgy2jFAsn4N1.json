      "id": "fetch-daily-provider-calls",
      "name": "Fetch Daily Provider Calls",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        500
      ],
      "retryOnFail": true,
