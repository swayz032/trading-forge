      "onError": "continueRegularOutput",
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const receipts = $('Fetch Daily Receipts').all().map(i => i.json);\nconst flatReceipts = Array.isArray(receipts[0]) ? receipts[0] : receipts;\nconst providerCalls = $('Fetch Daily Provider Calls').all().map(i => i.json);\nconst flatCalls = Array.isArray(providerCalls[0]) ? providerCalls[0] : providerCalls;\n\nconst receiptsByStatus = {};\nfor (const r of flatReceipts) {\n  const s = r.status || 'unknown';\n  receiptsByStatus[s] = (receiptsByStatus[s] || 0) + 1;\n}\n\nconst callsByProvider = {};\nlet totalDuration = 0;\nfor (const c of flatCalls) {\n  const p = c.provider || 'unknown';\n  if (!callsByProvider[p]) callsByProvider[p] = { total: 0, failed: 0, avgDuration: 0, durations: [] };\n  callsByProvider[p].total++;\n  callsByProvider[p].durations.push(c.duration_ms || 0);\n  if (c.status === 'failed' || c.status === 'timeout') callsByProvider[p].failed++;\n  totalDuration += (c.duration_ms || 0);\n}\n\nfor (const p of Object.keys(callsByProvider)) {\n  const d = callsByProvider[p].durations;\n  callsByProvider[p].avgDuration = Math.round(d.reduce((a, b) => a + b, 0) / d.length);\n  delete callsByProvider[p].durations;\n}\n\nreturn [{ json: {\n  date: new Date().toISOString().split('T')[0],\n  totalReceipts: flatReceipts.length,\n  receiptsByStatus,\n  totalProviderCalls: flatCalls.length,\n  callsByProvider,\n  avgCallDuration: flatCalls.length ? Math.round(totalDuration / flatCalls.length) : 0\n} }];"
      },
