      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        470,
        300
      ],
      "parameters": {
        "jsCode": "const strategyId = $input.first().json.body?.strategy_id;\nif (!strategyId || !/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i.test(strategyId)) {\n  throw new Error('Invalid strategy_id: must be a valid UUID');\n}\nreturn [{ json: { strategy_id: strategyId } }];"
      }
