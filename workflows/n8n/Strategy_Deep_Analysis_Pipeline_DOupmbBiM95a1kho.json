    {
      "id": "poll-backtest",
      "name": "Poll Backtest Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1020,
        300
      ],
      "parameters": {
        "jsCode": "// Poll backtest until complete\nconst backtestId = $input.first().json.backtestId;\nconst maxAttempts = 20; // 20 x 15s = 5 min\nconst interval = 15000;\n\nfor (let i = 0; i < maxAttempts; i++) {\n  const response = await fetch(`http://localhost:4000/api/backtests/${backtestId}`);\n  const data = await response.json();\n\n  if (data.status === 'completed') {\n    return [{ json: data }];\n  }\n  if (data.status === 'failed') {\n    throw new Error(`Backtest failed: ${data.error || 'unknown'}`);\n  }\n\n  await new Promise(resolve => setTimeout(resolve, interval));\n}\n\nthrow new Error('Backtest timed out after 5 minutes');"
      }
    },
    {
      "id": "poll-matrix",
      "name": "Poll Matrix Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1460,
        100
      ],
      "parameters": {
        "jsCode": "// Poll matrix until complete\nconst matrixId = $input.first().json.id || $input.first().json.matrixId;\nconst maxAttempts = 30; // 30 x 30s = 15 min\nconst interval = 30000;\n\nfor (let i = 0; i < maxAttempts; i++) {\n  const response = await fetch(`http://localhost:4000/api/backtests/matrix/${matrixId}`);\n  const data = await response.json();\n\n  if (data.status === 'completed') {\n    return [{ json: data }];\n  }\n  if (data.status === 'failed') {\n    throw new Error(`Matrix failed: ${data.error || 'unknown'}`);\n  }\n\n  await new Promise(resolve => setTimeout(resolve, interval));\n}\n\nthrow new Error('Matrix timed out after 15 minutes');"
      }
    },
    {
      "id": "poll-mc",
      "name": "Poll MC Status",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1570,
        100
      ],
      "parameters": {
        "jsCode": "// Poll Monte Carlo until complete\nconst mcId = $input.first().json.id || $input.first().json.mcId;\nconst maxAttempts = 20; // 20 x 15s = 5 min\nconst interval = 15000;\n\nfor (let i = 0; i < maxAttempts; i++) {\n  const response = await fetch(`http://localhost:4000/api/monte-carlo/${mcId}`);\n  const data = await response.json();\n\n  if (data.status === 'completed') {\n    return [{ json: data }];\n  }\n  if (data.status === 'failed') {\n    throw new Error(`Monte Carlo failed: ${data.error || 'unknown'}`);\n  }\n\n  await new Promise(resolve => setTimeout(resolve, interval));\n}\n\nthrow new Error('Monte Carlo timed out after 5 minutes');"
      }
    }
