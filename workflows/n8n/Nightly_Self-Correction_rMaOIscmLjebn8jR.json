  "name": "Nightly Self-Correction",
  "description": null,
  "active": false,
  "isArchived": false,
  "nodes": [
    {
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        250,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 23 * * 1-5"
            }
          ]
        }
      }
    },
    {
      "id": "fetch-sessions",
      "name": "Fetch Active Paper Sessions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        470,
        300
      ],
      "parameters": {
        "url": "http://localhost:4000/api/paper/sessions",
        "method": "GET",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "status",
              "value": "active"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      }
    },
    {
      "id": "split-sessions",
      "name": "Split Sessions",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        690,
        300
      ],
      "parameters": {
        "batchSize": 1
      }
    },
    {
      "id": "detect-drift",
      "name": "Detect Drift",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        910,
        300
      ],
      "parameters": {
        "url": "=http://localhost:4000/api/paper/drift/{{ $json.id }}?strategyId={{ $json.strategyId }}",
        "method": "GET",
        "options": {
          "timeout": 30000
        }
      },
      "continueOnFail": true
    },
    {
      "id": "check-drift",
      "name": "IF Drift > 2\u03c3",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
        1130,
        300
      ],
      "parameters": {
        "conditions": {
          "combinator": "or",
          "options": {
            "version": 2,
            "leftValue": "",
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "condition-drift",
              "leftValue": "={{ $json.driftScore }}",
              "rightValue": 2,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            },
            {
              "id": "condition-mc-pct",
              "leftValue": "={{ $json.mc_percentile }}",
              "rightValue": 10,
              "operator": {
                "type": "number",
                "operation": "lt"
              }
            }
          ]
        }
      }
    },
    {
      "id": "ollama-drift-critique",
      "name": "Ollama Drift Critique",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1350,
        200
      ],
      "parameters": {
        "url": "http://localhost:11434/api/generate",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama3:8b', prompt: 'This strategy is drifting from backtest expectations. Drift score: ' + $('Detect Drift').first().json.driftScore + '. MC percentile: ' + ($('Compare Paper to MC').first().json.mc_percentile || 'N/A') + '. Paper metrics vs backtest diverging. Check: regime shift? Execution quality? Slippage > assumptions? Recommendation: continue, reduce size, or stop?', stream: false }) }}",
        "options": {
          "timeout": 120000
        }
      },
      "continueOnFail": true
    },
    {
      "id": "lifecycle-check",
      "name": "Lifecycle Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1570,
        200
      ],
      "parameters": {
        "url": "http://localhost:4000/api/strategies/lifecycle/check"
      },
      "continueOnFail": true
    },
    {
      "id": "journal-nightly",
      "name": "Journal Nightly Summary",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1790,
        300
      ],
      "parameters": {
        "url": "http://localhost:4000/api/journal",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ source: 'n8n', status: 'tested', analystNotes: 'Nightly review: ' + $('Fetch Active Paper Sessions').all().length + ' active sessions checked' }) }}"
      },
      "continueOnFail": true
    },
    {
      "id": "broadcast-nightly",
      "name": "Broadcast Nightly SSE",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2010,
        300
      ],
      "parameters": {
        "url": "http://localhost:4000/api/sse/broadcast",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ type: 'nightly:review-complete', data: { timestamp: new Date().toISOString() } }) }}"
      },
      "continueOnFail": true
    },
    {
      "id": "1142ff2e-0a35-49f5-9e2e-498ea320eb72",
      "name": "Compare Paper to MC",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1020,
        200
      ],
      "parameters": {
        "method": "GET",
        "url": "=http://localhost:4000/api/paper/mc-compare/{{ $json.id }}",
        "options": {
          "timeout": 30000
        }
      }
    }
  ],
