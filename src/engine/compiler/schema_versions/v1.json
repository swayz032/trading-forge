{
  "$defs": {
    "Direction": {
      "enum": [
        "long",
        "short",
        "both"
      ],
      "title": "Direction",
      "type": "string"
    },
    "EntryType": {
      "enum": [
        "breakout",
        "mean_reversion",
        "trend_follow",
        "volatility_expansion",
        "session_pattern"
      ],
      "title": "EntryType",
      "type": "string"
    },
    "ExitType": {
      "enum": [
        "fixed_target",
        "trailing_stop",
        "time_exit",
        "indicator_signal",
        "atr_multiple"
      ],
      "title": "ExitType",
      "type": "string"
    },
    "Timeframe": {
      "enum": [
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "4h",
        "1d"
      ],
      "title": "Timeframe",
      "type": "string"
    },
    "MultiTimeframeEntry": {
      "description": "Optional higher-timeframe confirmation for entry signals",
      "properties": {
        "timeframe": {
          "$ref": "#/$defs/Timeframe"
        },
        "indicator": {
          "description": "Indicator on the higher timeframe (e.g. trend_bias, regime_filter)",
          "type": "string"
        },
        "condition": {
          "description": "Required condition on higher TF (e.g. above_200ma, trending_up)",
          "type": "string"
        }
      },
      "required": ["timeframe", "indicator", "condition"],
      "title": "MultiTimeframeEntry",
      "type": "object"
    },
    "SessionHours": {
      "description": "Explicit trading hours constraint (ET timezone)",
      "properties": {
        "start": {
          "description": "Start time in HH:MM format (ET), e.g. 09:30",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "type": "string"
        },
        "end": {
          "description": "End time in HH:MM format (ET), e.g. 16:00",
          "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$",
          "type": "string"
        },
        "no_new_entries_before_close_mins": {
          "description": "Block new entries N minutes before session end",
          "minimum": 0,
          "maximum": 120,
          "type": "integer"
        }
      },
      "required": ["start", "end"],
      "title": "SessionHours",
      "type": "object"
    },
    "SizingConfig": {
      "description": "Position sizing configuration",
      "properties": {
        "method": {
          "description": "Sizing method: dynamic_atr (scale by volatility) or fixed",
          "enum": ["dynamic_atr", "fixed"],
          "type": "string"
        },
        "target_risk_dollars": {
          "description": "Dollar risk per trade for dynamic_atr sizing",
          "minimum": 50,
          "maximum": 5000,
          "type": "number"
        },
        "fixed_contracts": {
          "description": "Fixed contract count when method=fixed",
          "minimum": 1,
          "maximum": 20,
          "type": "integer"
        }
      },
      "required": ["method"],
      "title": "SizingConfig",
      "type": "object"
    },
    "SlippageAssumptions": {
      "description": "Explicit slippage modeling assumptions for realistic backtesting",
      "properties": {
        "base_ticks": {
          "description": "Base slippage in ticks (applied to all trades)",
          "minimum": 0,
          "maximum": 10,
          "type": "number"
        },
        "high_vol_multiplier": {
          "description": "Slippage multiplier during high volatility (ATR percentile > 80)",
          "minimum": 1.0,
          "maximum": 5.0,
          "type": "number"
        },
        "news_event_multiplier": {
          "description": "Slippage multiplier during FOMC/CPI/NFP events",
          "minimum": 1.0,
          "maximum": 10.0,
          "type": "number"
        },
        "overnight_multiplier": {
          "description": "Slippage multiplier for ETH (overnight) fills",
          "minimum": 1.0,
          "maximum": 5.0,
          "type": "number"
        }
      },
      "required": ["base_ticks"],
      "title": "SlippageAssumptions",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Strategy Definition Language \u2014 the strict schema every strategy must conform to.",
  "properties": {
    "schema_version": {
      "default": "v1",
      "description": "DSL schema version",
      "title": "Schema Version",
      "type": "string"
    },
    "name": {
      "maxLength": 100,
      "minLength": 3,
      "title": "Name",
      "type": "string"
    },
    "description": {
      "description": "One-sentence strategy description",
      "maxLength": 500,
      "minLength": 10,
      "title": "Description",
      "type": "string"
    },
    "symbol": {
      "description": "Futures symbol (ES, NQ, CL, MES, MNQ, MCL)",
      "title": "Symbol",
      "type": "string"
    },
    "timeframe": {
      "$ref": "#/$defs/Timeframe"
    },
    "direction": {
      "$ref": "#/$defs/Direction"
    },
    "entry_type": {
      "$ref": "#/$defs/EntryType"
    },
    "entry_indicator": {
      "description": "Primary indicator for entry (e.g., 'sma_crossover', 'bollinger_breakout', 'rsi_reversal')",
      "title": "Entry Indicator",
      "type": "string"
    },
    "entry_params": {
      "additionalProperties": true,
      "description": "Max 5 parameters for entry logic",
      "title": "Entry Params",
      "type": "object"
    },
    "entry_condition": {
      "description": "Plain English entry rule, one sentence",
      "title": "Entry Condition",
      "type": "string"
    },
    "exit_type": {
      "$ref": "#/$defs/ExitType"
    },
    "exit_params": {
      "additionalProperties": true,
      "description": "Exit parameters (target, stop, trail)",
      "title": "Exit Params",
      "type": "object"
    },
    "stop_loss_atr_multiple": {
      "description": "Stop loss as ATR multiple",
      "maximum": 5.0,
      "minimum": 0.5,
      "title": "Stop Loss Atr Multiple",
      "type": "number"
    },
    "take_profit_atr_multiple": {
      "anyOf": [
        {
          "maximum": 10.0,
          "minimum": 1.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Take Profit Atr Multiple"
    },
    "max_contracts": {
      "anyOf": [
        {
          "maximum": 20,
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Contracts"
    },
    "preferred_regime": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "TRENDING_UP | TRENDING_DOWN | RANGE_BOUND | HIGH_VOL | LOW_VOL",
      "title": "Preferred Regime"
    },
    "session_filter": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "RTH_ONLY | ETH_ONLY | ALL_SESSIONS | LONDON | ASIA",
      "title": "Session Filter"
    },
    "source": {
      "default": "manual",
      "description": "manual | ollama | openclaw | n8n",
      "title": "Source",
      "type": "string"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "multi_timeframe": {
      "anyOf": [
        {
          "$ref": "#/$defs/MultiTimeframeEntry"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional higher-timeframe confirmation filter for entries",
      "title": "Multi Timeframe"
    },
    "session_hours": {
      "anyOf": [
        {
          "$ref": "#/$defs/SessionHours"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Explicit trading hours constraint (overrides session_filter for precise control)",
      "title": "Session Hours"
    },
    "sizing": {
      "anyOf": [
        {
          "$ref": "#/$defs/SizingConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Position sizing configuration (default: dynamic_atr with $500 target risk)",
      "title": "Sizing"
    },
    "invalidation_conditions": {
      "anyOf": [
        {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Conditions that invalidate the setup before entry (e.g. 'price gaps > 1 ATR at open')",
      "title": "Invalidation Conditions"
    },
    "slippage_assumptions": {
      "anyOf": [
        {
          "$ref": "#/$defs/SlippageAssumptions"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Explicit slippage modeling assumptions for realistic backtesting",
      "title": "Slippage Assumptions"
    }
  },
  "required": [
    "name",
    "description",
    "symbol",
    "timeframe",
    "direction",
    "entry_type",
    "entry_indicator",
    "entry_params",
    "entry_condition",
    "exit_type",
    "exit_params",
    "stop_loss_atr_multiple"
  ],
  "title": "StrategyDSL",
  "type": "object"
}
