# Trading Forge — Environment Variables Template
# Copy to .env and fill in your values

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:port/database
DB_POOL_MAX=4

# Databento — Historical futures data
DATABENTO_API_KEY=your-databento-api-key

# AWS S3 — Data lake
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=trading-forge-data

# Alpha Vantage — Technical indicators + sentiment
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# Server
PORT=4000
NODE_ENV=development
TF_RUNTIME_STAGE=development
TF_STRICT_PRODUCTION_READINESS=0
LOG_LEVEL=info
API_KEY=your-api-key
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Pause/resume reconciliation — G4.1 scaffolding (audit snapshot of in-flight
# positions when pipeline pauses). Disabled by default to avoid surprise audit
# noise; enable in production once snapshot semantics are verified for your
# workload. See pipeline-control-service.ts:135.
PAUSE_SNAPSHOT_ENABLED=false

# Backtest parity gates. Production hardening (2026-04-29) flipped defaults
# from "shadow" to "enforce". Override to "shadow" (compute but don't block)
# or "off" (skip entirely) for debugging. Skip engine + anti-setup gate now
# enforced in backtest by default to match paper-engine behavior (closes
# the §9 "gate honesty" parity gap).
TF_BACKTEST_SKIP_MODE=enforce
TF_BACKTEST_ANTI_SETUP_MODE=enforce

# Backtest compliance gate. "off" | "shadow" (log violations) |
# "enforce" (block signals that fail compliance). Default "shadow" — flip
# to "enforce" once compliance rule freshness pipeline is verified for
# your firm set. See backtester.py _apply_backtest_parity_gates.
TF_BACKTEST_COMPLIANCE_MODE=shadow

# Paper signal skip mode. "off" | "shadow" (log decisions) |
# "enforce" (block SKIP, reduce REDUCE, allow TRADE). Default "enforce"
# for production hardening. Set "shadow" for debug-only mode.
TF_PAPER_SKIP_MODE=enforce

# Determinism verification — opt-in two-run identity check at backtester
# startup. Doubles backtest time; only enable in CI / nightly verification jobs.
TF_VERIFY_DETERMINISM=0

# Python subprocess pool concurrency cap. Global semaphore — prevents
# overspawning across SQA / QUBO / tensor / RL / quantum-MC / backtest /
# walk-forward / DeepAR. Sized for the Skytech tower; tune to ~CPU_COUNT-2.
MAX_PYTHON_SUBPROCESSES=6

# Survival score weighting in forge_score (G3 follow-up). When "true",
# performance_gate.py adds the survival score as a forge_score component
# (default weight 25). Default "false" — shadow rollout in progress.
TF_SURVIVAL_IN_FORGE_SCORE=false

# Ollama — Local AI model server
OLLAMA_HOST=http://localhost:11434

# Discord Bot
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-application-id
DISCORD_PUBLIC_KEY=your-public-key
DISCORD_ALERT_PORT=4100

# Massive — Real-time WebSocket streaming
MASSIVE_API_KEY=your_massive_api_key_here

# OpenClaw Strategy Scout
BRAVE_API_KEY=your-brave-search-api-key
TAVILY_API_KEY=your-tavily-api-key
OPENCLAW_GATEWAY_TOKEN=your-openclaw-gateway-token
EXA_API_KEY=your-exa-api-key
PARALLEL_API_KEY=your-parallel-api-key

# Discord channels for OpenClaw structured reporting
# Run scripts/setup-discord-channels.ts to provision these
DISCORD_CH_N8N_DAILY_REPORT=
DISCORD_CH_STRATEGY_FINDS=
DISCORD_CH_WORKFLOW_ERRORS=
DISCORD_CH_CRITICAL_ALERTS=

# ═══════════════════════════════════════════════════════════════
# CLOUD QUANTUM + DEEPAR CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# IBM Quantum Platform (free tier, 10 min/month QPU)
IBM_QUANTUM_TOKEN=your-ibm-quantum-token
IBM_QUANTUM_INSTANCE=open-instance
IBM_QUANTUM_BUDGET_SECONDS=600

# AWS Braket (uses existing AWS creds, $30/month budget cap)
BRAKET_REGION=us-east-1
BRAKET_BUDGET_DOLLARS=30
BRAKET_S3_BUCKET=amazon-braket-trading-forge

# Cloud QPU global switch (TWO gates: this + per-request opt_in)
QUANTUM_CLOUD_ENABLED=false

# ═══════════════════════════════════════════════════════════════
# GEMINI QUANTUM BLUEPRINT FEATURE FLAGS (W1 / Tier 0.3)
# ═══════════════════════════════════════════════════════════════
# All flags default OFF (shadow). They control phased rollout of quantum
# modules built in W2-W4. Kill switch: `unset $VAR && systemctl restart`.

# QAE → Lifecycle Gate (Tier 1.1). 0 = shadow (read both, log only),
# 1 = advisory disagree alerts, 2 = quantum participates in gate.
# Wave 7 graduation flips after 30+ days agreement data.
QUANTUM_QAE_GATE_PHASE=0

# Tier 3.1 QCNN noise-score skip-engine signal.
QUANTUM_ENTROPY_FILTER_ENABLED=false

# Tier 3.2 reserved (deferred per architect review).
QUANTUM_COUNTERFACTUAL_ENABLED=false

# Tier 2 SQA graveyard-aware penalty in build_parameter_qubo().
QUANTUM_GRAVEYARD_QUBO_ENABLED=false

# Tier 3.3 A+ Market Auditor cron + cross-market lead-lag entanglement.
QUANTUM_AMARKET_AUDITOR_ENABLED=false

# Tier 3.4 Grover worst-case sequencer pre-PAPER promotion check.
QUANTUM_ADVERSARIAL_STRESS_ENABLED=false

# Tier 4 cuQuantum GPU acceleration. Requires VRAM probe pass; falls back
# to CPU automatically if VRAM insufficient.
QUANTUM_CUQUANTUM_GPU_ENABLED=false

# DeepAR Regime Forecaster (local, $0/month)
DEEPAR_ENABLED=true
DEEPAR_MODEL_DIR=./models/deepar
DEEPAR_TRAINING_EPOCHS=50
DEEPAR_PREDICTION_HORIZON=5
DEEPAR_CONTEXT_LENGTH=60
