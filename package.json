{
  "name": "trading-forge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "tsc",
    "build:frontend": "cd Trading_forge_frontend/amber-vision-main && npm run build",
    "build:all": "npm run build:frontend && npm run build",
    "start": "node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "lint": "eslint src/",
    "forge": "tsx scripts/cli.ts",
    "discord": "tsx src/discord/bot.ts",
    "discord:dev": "tsx watch src/discord/bot.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/lib-storage": "^3.1005.0",
    "discord.js": "^14.25.1",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.1",
    "duckdb-async": "^1.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.7",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.20.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.1.0"
  }
}
